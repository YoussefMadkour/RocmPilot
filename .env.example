# ---- Fireworks AI (reasoning agents + embeddings; all AMD-hosted) ----
FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/deepseek-v4-pro
FIREWORKS_EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5
EMBEDDING_DIM=768
# Per-agent models (override to remix the multi-model orchestra):
# PLANNER_MODEL / CRITIC_MODEL / RESEARCH_MODEL / REPORT_MODEL / EXPLAINER_MODEL

# ---- Qdrant Cloud (ROCm/HIP migration knowledge base — RAG). Optional:
# with these blank, agents run without retrieval (no-op). Run
# `python -m app.knowledge.ingest` after setting them to build the index.
QDRANT_URL=
QDRANT_API_KEY=
KNOWLEDGE_COLLECTION=rocm_migration_docs
KNOWLEDGE_TOP_K=5

# ---- Optional web research for the self-heal agent (no-op if blank) ----
TAVILY_API_KEY=

# ---- Validation ----
# replay = load a saved successful AMD validation run (demo-safe)
# live   = execute build/smoke-test/benchmark in the environment
VALIDATION_MODE=replay
AMD_VALIDATION_LOG_PATH=backend/app/fixtures/validation_log.txt

# ---- Optional: private GitHub repo cloning ----
GITHUB_TOKEN=

# ---- Frontend -> backend base URL ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
