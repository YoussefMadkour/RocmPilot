"""AMD/ROCm smoke test generated by RocmPilot Studio.

Prints a clear PASS/FAIL and enough environment detail to prove the repo runs on
AMD. Note: on ROCm, torch.cuda.is_available() returns True and devices appear
under the torch.cuda namespace — this is HIP, not NVIDIA CUDA.
"""
import sys

import torch


def main() -> int:
    print("=== RocmPilot smoke test ===")
    print(f"torch version        : {torch.__version__}")

    hip_version = getattr(torch.version, "hip", None)
    print(f"HIP / ROCm version   : {hip_version or 'not a ROCm build'}")

    accel = torch.cuda.is_available()
    print(f"accelerator available: {accel}")
    if accel:
        print(f"device name          : {torch.cuda.get_device_name(0)}")

    device = torch.device("cuda" if accel else "cpu")
    print(f"selected device      : {device}")

    # Tiny real workload so we actually exercise the device.
    a = torch.randn(512, 512, device=device)
    b = torch.randn(512, 512, device=device)
    c = (a @ b).sum().item()

    ok = torch.isfinite(torch.tensor(c)).item()
    print(f"matmul result finite : {ok}")
    print("PASS" if ok else "FAIL")
    return 0 if ok else 1


if __name__ == "__main__":
    sys.exit(main())
